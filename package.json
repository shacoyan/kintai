{
  "name": "kintai",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "test": "vitest run",
    "preview": "vite preview",
    "e2e:install": "playwright install chromium",
    "e2e:smoke": "playwright test --project=chromium-anon e2e/smoke.spec.ts",
    "e2e:a11y": "playwright test --project=chromium e2e/a11y.spec.ts",
    "e2e:visual": "playwright test --project=chromium e2e/visual-regression.spec.ts",
    "e2e:visual:update": "playwright test --project=chromium e2e/visual-regression.spec.ts --update-snapshots",
    "lint:colors": "bash scripts/check-direct-colors.sh",
    "i18n:extract": "node scripts/extract-i18n.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@supabase/supabase-js": "^2.39.0",
    "date-fns": "^3.0.0",
    "date-fns-tz": "^3.2.0",
    "japanese-holidays": "^1.0.10",
    "lucide-react": "^1.11.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.20.0",
    "recharts": "^2.12.7"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@playwright/test": "^1.59.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.0",
    "dotenv": "^16.4.5",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
