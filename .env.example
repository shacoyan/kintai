# Supabase プロジェクト設定
# https://app.supabase.com/ のプロジェクト設定 > API から取得

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# === Wave4 Square 売上 API（Vercel Functions / api/*.js 用サーバ env）===
# フロント用 VITE_ プレフィックス無し。api/_auth.js / api/_shared.js が参照する。
# api/_auth.js が anon key + ユーザー JWT 載せ替えで get_allowed_location_ids を呼ぶため、
# SUPABASE_URL / SUPABASE_ANON_KEY は VITE_ 版と同値でよい（service role は使わない）。
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
# Square API アクセストークン（売上 / 取引 / カタログ取得）
SQUARE_ACCESS_TOKEN=your-square-access-token

# E2E 認証（テスト専用 Supabase ユーザー）
# 未設定なら e2e/fixtures/auth.setup.ts は自動 skip され、chromium project（認証必須テスト）も skip される。
# chromium-anon project（smoke.spec.ts）は認証なしで動作するため、未設定でも実行可能。
E2E_USER_EMAIL=
E2E_USER_PASSWORD=

# === 1month E2E テスト専用 (project=e2e-1month) ===
# 設計書: .company/engineering/docs/2026-05-07-kintai-1month-shift-e2e-techdesign.md
# テナント: テスト株式会社 (Supabase 本番 zjjbfffhbobwwxyvdszl)
# 実行: npm run e2e -- --project=e2e-1month
# パスワードは秘書側で .env.local に直接投入する (.env.local は gitignore 済)。
E2E_TENANT_ID=786f041f-4d89-4d5e-bf1b-b4c23dd38b0c
E2E_TENANT_NAME=テスト株式会社
E2E_STORE_HONTEN_ID=ffccc5e6-f579-41cd-8f80-13572dec3424
E2E_STORE_BUNTEN_ID=ffe60523-b9bb-4604-91dc-dec3b945a137

# 店長 (承認担当)
E2E_USER_TEST02_EMAIL=test02@kintai.local
E2E_USER_TEST02_PASSWORD=

# 予備店長 (本テストでは未使用、将来用)
E2E_USER_TEST03_EMAIL=test03@kintai.local
E2E_USER_TEST03_PASSWORD=

# スタッフ 1: 本店 13:00-21:00
E2E_USER_TEST04_EMAIL=test04@kintai.local
E2E_USER_TEST04_PASSWORD=

# スタッフ 2: 本店 21:00-23:45 (深夜跨ぎは validateTimeRange で弾かれるため丸め)
E2E_USER_TEST05_EMAIL=test05@kintai.local
E2E_USER_TEST05_PASSWORD=

# スタッフ 3: 分店 17:00-22:00
E2E_USER_TEST06_EMAIL=test06@kintai.local
E2E_USER_TEST06_PASSWORD=

# クリーンアップを Playwright globalSetup で自動実行する場合は 1。デフォルト 0 (手動 SQL 実行)。
E2E_AUTO_CLEANUP=0

